{
  "metadata": [
    {
      "src": [
        {
          "src": "../src/Aspire.Hosting.Netlify",
          "files": [ "Aspire.Hosting.Netlify.csproj" ]
        }
      ],
      "dest": ".",
      "outputFormat": "mref",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "EnumSortOrder": "alphabetic",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "*.md", "*.yml" ],
        "exclude": [ "_site/**" ]
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "Aspire.Hosting.Netlify",
      "_appTitle": "Aspire.Hosting.Netlify API Reference",
      "_appLogoPath": "public/logo.svg",
      "_appFaviconPath": "public/logo.svg",
      "_appFooter": "<span>API reference generated from XML doc comments. <a href=\"../\">Back to docs</a> · <a href=\"https://github.com/IEvangelist/netlify-aspire-integration\">GitHub</a></span>",
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/IEvangelist/netlify-aspire-integration",
        "branch": "main"
      },
      "_enableSearch": true
    },
    "template": [
      "default",
      "modern",
      "templates/aspire-ember"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}


