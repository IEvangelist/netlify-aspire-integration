---
// FrameworkRow.astro — horizontal logo strip of the JS frameworks supported
// by Aspire.Hosting.Netlify. Each logo links to its framework guide page.
//
// Default render: monochrome currentColor, sized 26x26 in a 56x56 chip.
// On hover: the chip lifts, the logo flips to its brand color (per-card
// CSS var --brand-rgb), and the chip border picks up the brand glow.
//
// Logos come from the official Simple Icons collection via astro-icon
// (`@iconify-json/simple-icons`, CC0 1.0). Single-path / currentColor so
// the same icon recolors on hover via CSS.

import { Icon } from "astro-icon/components";

interface Framework {
  name: string;
  href: string;
  /** Iconify name from the simple-icons collection. */
  iconName: string;
  /** Brand RGB triplet for hover state, e.g. "221 0 49". */
  brand: string;
}

const FRAMEWORKS: Framework[] = [
  {
    name: "Angular",
    href: "/netlify-aspire-integration/frameworks/angular/",
    brand: "221 0 49",
    iconName: "simple-icons:angular",
  },
  {
    name: "Astro",
    href: "/netlify-aspire-integration/frameworks/astro/",
    brand: "255 90 35",
    iconName: "simple-icons:astro",
  },
  {
    name: "Next.js",
    href: "/netlify-aspire-integration/frameworks/nextjs/",
    brand: "15 15 15",
    iconName: "simple-icons:nextdotjs",
  },
  {
    name: "React",
    href: "/netlify-aspire-integration/frameworks/react/",
    brand: "97 218 251",
    iconName: "simple-icons:react",
  },
  {
    name: "Svelte",
    href: "/netlify-aspire-integration/frameworks/svelte/",
    brand: "255 62 0",
    iconName: "simple-icons:svelte",
  },
  {
    name: "Vue",
    href: "/netlify-aspire-integration/frameworks/vue/",
    brand: "65 184 131",
    iconName: "simple-icons:vuedotjs",
  },
];
---

<nav class="frameworks" aria-label="Supported frameworks">
  <span class="frameworks__lead" aria-hidden="true">Works with</span>
  <ul class="frameworks__list" role="list">
    {FRAMEWORKS.map((f) => (
      <li class="frameworks__item" role="listitem">
        <a class="framework" href={f.href} style={`--brand-rgb: ${f.brand};`} aria-label={f.name}>
          <span class="framework__chip" aria-hidden="true">
            <Icon name={f.iconName} class="framework__icon" width={26} height={26} />
          </span>
          <span class="framework__name">{f.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
