---

<nav class="frameworks" aria-label="Supported frameworks">
  <span class="frameworks__lead" aria-hidden="true">Works with</span>
  <ul class="frameworks__list" role="list">
    {FRAMEWORKS.map((f) => (
      <li class="frameworks__item" role="listitem">
        <a class="framework" href={f.href} style={`--brand-rgb: ${f.brand};`} aria-label={f.name}>
          <span class="framework__chip" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="26" height="26" set:html={f.svg} />
          </span>
          <span class="framework__name">{f.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
