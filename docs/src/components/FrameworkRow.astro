---
// FrameworkRow.astro — horizontal logo strip of the JS frameworks supported
// by Aspire.Hosting.Netlify. Each logo links to its framework guide page.
//
// Default render: monochrome currentColor, sized 28x28 in a 56x56 chip.
// On hover: the chip lifts, the logo flips to its brand color (per-card
// CSS var --brand-rgb), and the chip border picks up the brand glow.
//
// SVG paths come from Simple Icons (CC0 1.0) — we strip them down to a
// single fill="currentColor" path so the same icon recolors on hover.

interface Framework {
  name: string;
  href: string;
  /** Inline SVG content (paths/groups) using fill="currentColor". */
  svg: string;
  /** Brand RGB triplet for hover state, e.g. "221 0 49". */
  brand: string;
}

