---
// IconCard.astro — opinionated card with icon, gradient hover stroke, and a
// 3D tilt on hover. Drop-in replacement for Starlight LinkCard when an icon
// matters.
//
// Icons come from the official Lucide collection via astro-icon
// (`@iconify-json/lucide`, ISC). The public API at call sites stays the
// same — `icon="rocket"` resolves to `lucide:rocket` internally.
//
// Usage in MDX:
//   <IconCard icon="rocket" title="Quickstart" href="/foo/" desc="Drop-in." />

import { Icon } from "astro-icon/components";

type IconKey =
  | "rocket"
  | "terminal"
  | "key"
  | "puzzle"
  | "lock"
  | "settings"
  | "cloud"
  | "code"
  | "layers"
  | "shield-check"
  | "tag"
  | "circle-help"
  // Back-compat aliases for older call sites.
  | "shield"
  | "question";

interface Props {
  icon: IconKey;
  title: string;
  href: string;
  desc?: string;
  /** Render the link as an external (target=_blank) link. */
  external?: boolean;
  /**
   * Optional accent color hint: 'ember' | 'aurora' | 'plum'. Tints the icon
   * and the hover stroke. Defaults to a multi-stop gradient.
   */
  tint?: "ember" | "aurora" | "plum";
}

const { icon, title, href, desc, external = false, tint } = Astro.props;

// Map any legacy keys to current lucide names. New code should use the
// canonical lucide names directly.
const ALIASES: Record<string, string> = {
  shield: "shield-check",
  question: "circle-help",
};
const lucideName = ALIASES[icon] ?? icon;

const tintClass = tint ? `iconcard--${tint}` : "";
---

<a
  class={`iconcard ${tintClass}`}
  href={href}
  data-external={external ? "true" : null}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <span class="iconcard__icon" aria-hidden="true">
    <Icon name={`lucide:${lucideName}`} width={22} height={22} />
  </span>

  <span class="iconcard__body">
    <span class="iconcard__title">
      {title}
      <Icon name="lucide:chevron-right" class="iconcard__chev" width={16} height={16} aria-hidden="true" />
    </span>
    {desc && <span class="iconcard__desc">{desc}</span>}
  </span>
</a>
