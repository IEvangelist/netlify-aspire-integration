---
// StatRow.astro — bold "by-the-numbers" row used in the splash hero.
// Each stat is { value, label, icon? }. Icons are the official Lucide set
// pulled in via astro-icon (`@iconify-json/lucide`).

import { Icon } from "astro-icon/components";

type IconKey =
  | "terminal"
  | "lock"
  | "layers"
  | "code"
  | "rocket"
  | "zap"
  | "shield-check"
  | "package";

interface Stat { value: string; label: string; icon?: IconKey; }
interface Props { stats: Stat[]; }
const { stats } = Astro.props;
---

<div class="statrow" role="list">
  {stats.map((s) => (
    <div class="statrow__item" role="listitem">
      {s.icon && (
        <span class="statrow__icon" aria-hidden="true">
          <Icon name={`lucide:${s.icon}`} width={20} height={20} />
        </span>
      )}
      <span class="statrow__value">{s.value}</span>
      <span class="statrow__label">{s.label}</span>
    </div>
  ))}
</div>
