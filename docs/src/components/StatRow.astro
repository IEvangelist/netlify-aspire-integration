---
// StatRow.astro — bold "by-the-numbers" row used in the splash hero.
// Each stat is { value, label }.

interface Stat { value: string; label: string; }
interface Props { stats: Stat[]; }
const { stats } = Astro.props;
---

<div class="statrow" role="list">
  {stats.map((s) => (
    <div class="statrow__item" role="listitem">
      <span class="statrow__value">{s.value}</span>
      <span class="statrow__label">{s.label}</span>
    </div>
  ))}
</div>
