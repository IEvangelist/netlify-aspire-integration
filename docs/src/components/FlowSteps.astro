---
// FlowSteps.astro — 3-step "how it works" stack for the splash page.
// Renders Compose → Publish → Deploy as a vertical sequence with an icon
// per step and a downward chevron between cards so the order is unambiguous.
//
// The chevrons + ordered list semantics carry the sequence — we deliberately
// don't render a separate numbered badge so each card has a single visual
// anchor (the tinted icon chip) instead of two competing chips.
//
// Icons come from the official Lucide collection via astro-icon
// (`@iconify-json/lucide`, ISC).

import { Icon } from "astro-icon/components";

interface Step {
  title: string;
  desc: string;
  /** Iconify name from the lucide collection (without the `lucide:` prefix). */
  icon: string;
  /** Optional accent: bay | aurora | plum. */
  tint?: "bay" | "aurora" | "plum";
}

const STEPS: Step[] = [
  {
    title: "Compose",
    desc: "Wire your AppHost in C# or TypeScript. AddNetlifyDeployPipeline + PublishAsNetlifySite.",
    icon: "layers",
    tint: "bay",
  },
  {
    title: "Publish",
    desc: "aspire publish runs Aspire's pipeline; the integration emits a typed Netlify deploy step.",
    icon: "package",
    tint: "aurora",
  },
  {
    title: "Deploy",
    desc: "aspire deploy resolves auth, runs netlify deploy --prod, streams logs into Aspire.",
    icon: "rocket",
    tint: "plum",
  },
];
---

<ol class="flow" role="list">
  {STEPS.map((s, i) => (
    <li class={`flow__step flow__step--${s.tint ?? "bay"}`}>
      <span class="flow__icon" aria-hidden="true">
        <Icon name={`lucide:${s.icon}`} width={22} height={22} />
      </span>
      <span class="flow__body">
        <span class="flow__title">{s.title}</span>
        <span class="flow__desc">{s.desc}</span>
      </span>
      {i < STEPS.length - 1 && (
        <span class="flow__chev" aria-hidden="true">
          <Icon name="lucide:chevron-right" width={18} height={18} />
        </span>
      )}
    </li>
  ))}
</ol>

